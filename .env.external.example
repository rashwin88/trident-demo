# ── .env.external.example ─────────────────────────────────
# Configuration for external database deployment.
# Copy to .env.external and fill in your values.
#
#   cp .env.external.example .env.external

# ── LLM Provider ──────────────────────────────────────
# Options: openai | anthropic | ollama
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Embedding Provider ────────────────────────────────
# Options: openai | ollama
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=768

# Ollama (only if EMBEDDING_PROVIDER=ollama or LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Neo4j (external) ─────────────────────────────────
# For Neo4j Aura:      neo4j+s://xxxxxxxx.databases.neo4j.io
# For self-hosted:     bolt://your-neo4j-host:7687
# For same machine:    bolt://host.docker.internal:7687
NEO4J_URI=bolt://host.docker.internal:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# ── Milvus (external) ────────────────────────────────
# For Zilliz Cloud:    your-instance.api.gcp-us-west1.zillizcloud.com
# For self-hosted:     your-milvus-host
# For same machine:    host.docker.internal
MILVUS_HOST=host.docker.internal
MILVUS_PORT=19530

# ── Chunking ──────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
